{
  "_comment": "Backbone geometry + Ramachandran allowed regions consumed by periodica.folding and periodica.optimize. All chemistry/physics constants live here, not in code.",
  "version": 1,

  "bond_lengths_A": {
    "N_CA": 1.458,
    "CA_C": 1.525,
    "C_N":  1.329
  },
  "bond_angles_deg": {
    "N_CA_C": 111.2,
    "CA_C_N": 116.2,
    "C_N_CA": 121.7
  },
  "omega_deg": 180.0,

  "ramachandran_allowed": {
    "alpha_helix":      { "phi": [-100, -30],  "psi": [-80, -10] },
    "beta_sheet":       { "phi": [-180, -90],  "psi": [90, 180]  },
    "left_alpha_helix": { "phi": [30, 90],     "psi": [0, 90]    },
    "polyproline_II":   { "phi": [-90, -30],   "psi": [110, 180] }
  },

  "min_ca_distance_A": 3.5,

  "energy_weights": {
    "lambda_propensity": 1.0,
    "lambda_clash":      5.0,
    "lambda_ramachandran_disallowed": 2.0
  },

  "alphafold_api_template": "https://alphafold.ebi.ac.uk/api/prediction/{uniprot_id}",
  "alphafold_pdb_glob": "AF-{uniprot_id}-F1-model_v*.pdb"
}
