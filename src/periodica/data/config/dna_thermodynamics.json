{
  "name": "DNA Nearest-Neighbor Thermodynamic Parameters",
  "description": "SantaLucia (1998) unified nearest-neighbor parameters for DNA duplex stability",
  "reference": "SantaLucia, J. Jr. (1998). PNAS, 95(4), 1460-1465",
  "units": {
    "dH": "kcal/mol",
    "dS": "cal/(mol*K)"
  },
  "nearest_neighbor_params": {
    "AA/TT": {"dH": -7.9, "dS": -22.2},
    "AT/TA": {"dH": -7.2, "dS": -20.4},
    "TA/AT": {"dH": -7.2, "dS": -21.3},
    "CA/GT": {"dH": -8.5, "dS": -22.7},
    "GT/CA": {"dH": -8.4, "dS": -22.4},
    "CT/GA": {"dH": -7.8, "dS": -21.0},
    "GA/CT": {"dH": -8.2, "dS": -22.2},
    "CG/GC": {"dH": -10.6, "dS": -27.2},
    "GC/CG": {"dH": -9.8, "dS": -24.4},
    "GG/CC": {"dH": -8.0, "dS": -19.9}
  },
  "initiation_params": {
    "terminal_AT": {"dH": 2.3, "dS": 4.1},
    "terminal_GC": {"dH": 0.1, "dS": -2.8}
  },
  "symmetry_correction": {"dH": 0.0, "dS": -1.4},
  "nucleotide_molecular_weights": {
    "A": 331.2,
    "T": 322.2,
    "G": 347.2,
    "C": 307.2
  },
  "default_concentrations": {
    "Na_M": 0.05,
    "Mg_M": 0.0,
    "oligo_M": 2.5e-7
  }
}
